# Lumen Configuration
# Copy this file to .env and fill in your values.
# In production, set these as real environment variables instead.

# Required: API key that Prism (and any other client) must send as a Bearer token.
# Generate a strong random value, e.g.: openssl rand -hex 32
LUMEN_API_KEY=your-secret-api-key-here

# Optional: Port to listen on. Defaults to 9069.
# LUMEN_PORT=9069
